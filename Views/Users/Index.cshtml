@{
    ViewData["Title"] = "User Management";
    ViewData["PageIcon"] = "fas fa-users-cog";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
<div class="card-header d-flex align-items-center flex-wrap gap-2">
    <a asp-area="Identity" asp-controller="Account" asp-action="Register" class="btn btn-sm btn-gradient">
        <i class="fas fa-plus me-1"></i> Create New
    </a>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-body">
                <table id="usersTable" class="table table-striped table-bordered table-hover" style="width:100%">
                    <thead>
                        <tr>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Roles</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Reset Password Modal -->
<div class="modal fade" id="resetPasswordModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-key me-2"></i>Reset Password</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-3">Resetting password for: <strong id="resetUserEmail"></strong></p>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                    <input type="password" id="newPassword" class="form-control" placeholder="New password (min 6 chars)" />
                    <button class="btn btn-outline-secondary" type="button" id="togglePwd">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
                <div id="resetError" class="text-danger mt-2" style="display:none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-gradient" id="confirmResetBtn">
                    <i class="fas fa-save me-1"></i>Reset Password
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var table = $('#usersTable').DataTable({
                processing: true,
                serverSide: true,
                ajax: { url: '/Users/GetUsers', type: 'POST' },
                columns: [
                    { data: 'fullName' },
                    { data: 'email' },
                    {
                        data: 'roles',
                        orderable: false,
                        render: function (roles) {
                            if (!roles || roles.length === 0)
                                return '<span class="badge bg-secondary">No Role</span>';
                            return roles.map(r => {
                                var cls = r === 'Admin' ? 'bg-danger' : r === 'HR' ? 'bg-primary' : 'bg-success';
                                return `<span class="badge ${cls} me-1">${r}</span>`;
                            }).join('');
                        }
                    },
                    {
                        data: 'isLockedOut',
                        orderable: false,
                        render: function (locked) {
                            return locked
                                ? '<span class="badge bg-danger"><i class="fas fa-lock me-1"></i>Locked</span>'
                                : '<span class="badge bg-success"><i class="fas fa-unlock me-1"></i>Active</span>';
                        }
                    },
                    {
                        data: null,
                        orderable: false,
                        render: function (row) {
                            var lockIcon  = row.isLockedOut ? 'fa-unlock' : 'fa-lock';
                            var lockLabel = row.isLockedOut ? 'Unlock' : 'Lock';
                            var lockCls   = row.isLockedOut ? 'btn-warning' : 'btn-secondary';
                            return `
                                <a href="/Users/Edit/${row.id}" class="btn btn-sm btn-gradient me-1" title="Edit">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <button class="btn btn-sm ${lockCls} toggle-lock me-1"
                                        data-id="${row.id}" title="${lockLabel}">
                                    <i class="fas ${lockIcon}"></i>
                                </button>
                                <button class="btn btn-sm btn-info reset-pwd"
                                        data-id="${row.id}" data-email="${row.email}" title="Reset Password">
                                    <i class="fas fa-key"></i>
                                </button>`;
                        }
                    }
                ],
                dom: '<"row"<"col-sm-2"l><"col-sm-10"Bf>>' +
                     '<"row"<"col-sm-12"tr>>' +
                     '<"row"<"col-sm-5"i><"col-sm-7"p>>',
                pageLength: 10,
                lengthMenu: [[10, 25, 50], [10, 25, 50]],
                buttons: [
                    { extend: 'copy',  text: '<i class="fas fa-copy"></i> Copy',  className: 'btn btn-dt-primary btn-sm' },
                    { extend: 'excel', text: '<i class="fas fa-file-excel"></i> Excel', className: 'btn btn-dt-success btn-sm' },
                    { extend: 'pdf',   text: '<i class="fas fa-file-pdf"></i> PDF',   className: 'btn btn-dt-danger btn-sm' },
                    { extend: 'print', text: '<i class="fas fa-print"></i> Print', className: 'btn btn-dt-warning btn-sm' }                    
                ]
            });

            // Toggle lock
            $('#usersTable').on('click', '.toggle-lock', function () {
                var id = $(this).data('id');
                var btn = $(this);
                $.post('/Users/ToggleLock', { id })
                    .done(function (res) {
                        if (res.success) table.ajax.reload(null, false);
                    })
                    .fail(function () { alert('Failed to toggle lock.'); });
            });

            // Reset password modal
            var resetUserId = null;
            $('#usersTable').on('click', '.reset-pwd', function () {
                resetUserId = $(this).data('id');
                $('#resetUserEmail').text($(this).data('email'));
                $('#newPassword').val('');
                $('#resetError').hide();
                $('#resetPasswordModal').modal('show');
            });

            $('#togglePwd').on('click', function () {
                var inp = $('#newPassword');
                var isText = inp.attr('type') === 'text';
                inp.attr('type', isText ? 'password' : 'text');
                $(this).find('i').toggleClass('fa-eye fa-eye-slash');
            });

            $('#confirmResetBtn').on('click', function () {
                var pwd = $('#newPassword').val();
                var btn = $(this);
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span>Resetting...');
                $('#resetError').hide();

                $.post('/Users/ResetPassword', { id: resetUserId, newPassword: pwd })
                    .done(function (res) {
                        if (res.success) {
                            $('#resetPasswordModal').modal('hide');
                            alert('Password reset successfully.');
                        } else {
                            $('#resetError').text(res.message).show();
                        }
                    })
                    .fail(function () { $('#resetError').text('Request failed.').show(); })
                    .always(function () {
                        btn.prop('disabled', false).html('<i class="fas fa-save me-1"></i>Reset Password');
                    });
            });
        });
    </script>
}