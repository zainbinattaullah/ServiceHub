@model EditUserViewModel
@{
    ViewData["Title"] = "Edit User";
    ViewData["PageIcon"] = "fas fa-user-edit";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body p-4">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Email" />

                    <div class="mb-3">
                        <label class="form-label text-muted">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                            <input type="text" class="form-control" value="@Model.Email" disabled />
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-user"></i></span>
                                <input asp-for="FirstName" class="form-control" />
                            </div>
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-user"></i></span>
                                <input asp-for="LastName" class="form-control" />
                            </div>
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Assigned Roles</label>
                        <div class="border rounded p-3">
                            @foreach (var role in Model.AllRoles)
                            {
                                var isChecked = Model.SelectedRoles.Contains(role);
                                var badgeCls = role == "Admin" ? "bg-danger" : role == "HR" ? "bg-primary" : "bg-success";
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox"
                                           name="SelectedRoles"
                                           value="@role"
                                           id="role_@role"
                                    @(isChecked ? "checked" : "") />
                                    <label class="form-check-label" for="role_@role">
                                        <span class="badge @badgeCls">@role</span>
                                    </label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-gradient">
                            <i class="fas fa-save me-1"></i> Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i> Back
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}