<!--begin::Sidebar-->
<aside class="app-sidebar bg-body-secondary shadow" data-bs-theme="dark">

    <!--begin::Brand-->
    <div class="sidebar-brand">
        <a href="/Home/Index" class="brand-link d-flex align-items-center gap-2">
            <img src="/cust_theme_comp/assets/img/logo.png"
                 alt="Service Hub"
                 class="brand-image opacity-75 shadow"
                 style="height:200px !important;width:auto">
            @* <span class="brand-text fw-semibold">Service Group</span> *@
        </a>
    </div>
    <!--end::Brand-->

    <!--begin::Sidebar Wrapper-->
    <div class="sidebar-wrapper">
        <nav class="mt-2">
            <!--
                NOTE: data-lte-toggle="treeview" is intentionally removed.
                Our own jQuery below handles open/close so AdminLTE's handler
                does not fire a second time (which would cancel the first toggle).
            -->
            <ul class="nav sidebar-menu flex-column"
                role="menu">

                <!-- ── Dynamic role-based menu from DB ────────────────── -->
                @await Component.InvokeAsync("SidebarMenu")

                <!-- ── Admin-only fixed items ─────────────────────────── -->
                @if (User.IsInRole("Admin"))
                {
                    <!-- ── User Administration (treeview) ─────────── -->
                    <li class="nav-item">
                        <a href="#" class="nav-link">
                            <i class="nav-icon fas fa-users-cog"></i>
                            <p>
                                User Administration
                                <i class="nav-arrow fas fa-angle-right"></i>
                            </p>
                        </a>
                        <ul class="nav nav-treeview" style="display:none;">
                            <li class="nav-item">
                                <a href="/Identity/Account/Register" class="nav-link">
                                    <i class="nav-icon fas fa-user-plus"></i>
                                    <p>Create User</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="/Identity/Account/Manage/ChangePassword" class="nav-link">
                                    <i class="nav-icon fas fa-key"></i>
                                    <p>Change Password</p>
                                </a>
                            </li>
                        </ul>
                    </li>

                    <li class="nav-item">
                        <a asp-area="HR"
                           asp-controller="MenuManagement"
                           asp-action="Index"
                           class="nav-link">
                            <i class="nav-icon fas fa-list-alt"></i>
                            <p>Menu Management</p>
                        </a>
                    </li>
                }

            </ul>
        </nav>
    </div>
    <!--end::Sidebar Wrapper-->
</aside>
<!--end::Sidebar-->

<!-- Sidebar script — active state + treeview toggle -->
<script>
$(document).ready(function () {

    var currentPath = window.location.pathname.toLowerCase();

    // ── 1. Auto-mark active child links and open their parent ───────────
    $('.nav-treeview .nav-link').each(function () {
        var href = $(this).attr('href') || '';
        if (href !== '#' && currentPath.indexOf(href.toLowerCase()) === 0) {
            $(this).addClass('active');
            var $tree = $(this).closest('.nav-treeview');
            $tree.show();
            $tree.closest('.nav-item').addClass('menu-open');
        }
    });

    // ── 2. Auto-mark active top-level standalone links ───────────────────
    $('.sidebar-menu > .nav-item > .nav-link').each(function () {
        var href = $(this).attr('href') || '';
        if (href !== '#' && currentPath.indexOf(href.toLowerCase()) === 0) {
            $(this).addClass('active');
        }
    });

    // ── 3. Click handler — group toggle + leaf active ────────────────────
    $('.sidebar-menu').on('click', '.nav-link', function (e) {
        var $this    = $(this);
        var $tree    = $this.siblings('.nav-treeview');

        if ($tree.length) {
            // Group header — toggle submenu
            e.preventDefault();
            e.stopImmediatePropagation();   // prevent AdminLTE re-firing
            var opening = !$tree.is(':visible');
            $tree.slideToggle(160);
            $this.closest('.nav-item').toggleClass('menu-open', opening);
            return;
        }

        // Leaf link — update active state
        $('.sidebar-menu .nav-link').removeClass('active');
        $this.addClass('active');

        // Keep the parent group visible
        var $parentTree = $this.closest('.nav-treeview');
        if ($parentTree.length) {
            $parentTree.show();
            $parentTree.closest('.nav-item').addClass('menu-open');
        }
    });
});
</script>
