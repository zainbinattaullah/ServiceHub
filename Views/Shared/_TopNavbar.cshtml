<!--begin::Header-->
<nav class="app-header navbar navbar-expand bg-body">
    <div class="container-fluid">

        <!-- ── Left: sidebar toggle + page title ─────────────────────── -->
        <ul class="navbar-nav align-items-center">
            <li class="nav-item">
                <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                    <i class="fas fa-bars fs-5"></i>
                </a>
            </li>
            <li class="nav-item d-none d-sm-block">
                <span class="navbar-text fw-semibold ms-1" style="font-size:15px; color:var(--sh-text, #1e293b);">
                    @if (ViewData["PageIcon"] != null)
                    {
                        <i class="@ViewData["PageIcon"] me-2" style="color:var(--sh-primary)"></i>
                    }
                    @(ViewData["Title"] ?? "")
                </span>
            </li>
        </ul>

        <!-- ── Right: theme switcher + gearbox + user ────────────────── -->
        <ul class="navbar-nav ms-auto align-items-center gap-1">

            <!-- ⚙ Settings Gearbox — opens off-canvas settings panel -->
            <li class="nav-item">
                <button class="btn btn-link nav-link px-2"
                        type="button"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#settingsPanel"
                        aria-controls="settingsPanel"
                        title="Customise appearance">
                    <i class="fas fa-cog fs-5"></i>
                </button>
            </li>

            <!-- User menu -->
            <li class="nav-item dropdown">
                <a href="#" class="nav-link d-flex align-items-center gap-2"
                   id="userDropdown"
                   data-bs-toggle="dropdown"
                   aria-expanded="false">
                    <!-- Avatar circle with initials -->
                    <span class="sh-avatar">
                        @{
                            var uName    = User.Identity?.Name ?? "?";
                            var namePart = uName.Split('@')[0];
                            var initials = namePart.Length >= 2
                                ? namePart.Substring(0, 2).ToUpper()
                                : namePart.ToUpper();
                        }
                        @initials
                    </span>
                    <span class="fw-semibold d-none d-md-inline">@uName</span>

                    <!-- Role badge -->
                    @if (User.IsInRole("Admin"))
                    { <span class="badge sh-badge-admin">Admin</span> }
                    else if (User.IsInRole("HR"))
                    { <span class="badge sh-badge-hr">HR</span> }
                    else
                    { <span class="badge sh-badge-user">User</span> }

                    <i class="fas fa-chevron-down small ms-1"></i>
                </a>
                <ul class="dropdown-menu dropdown-menu-end shadow-lg"
                    aria-labelledby="userDropdown">
                    <li class="dropdown-header text-muted">
                        <i class="fas fa-user-circle me-1"></i> @uName
                    </li>
                    <li>
                        <a class="dropdown-item" href="/Identity/Account/Manage">
                            <i class="fas fa-id-card me-2"></i> My Profile
                        </a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li>
                            <a class="dropdown-item"
                               asp-area="HR"
                               asp-controller="MenuManagement"
                               asp-action="Index">
                                <i class="fas fa-list-alt me-2"></i> Menu Management
                            </a>
                        </li>
                    }
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <form method="post" asp-area="Identity" asp-page="/Account/Logout">
                            <button type="submit" class="dropdown-item text-danger">
                                <i class="fas fa-sign-out-alt me-2"></i> Logout
                            </button>
                        </form>
                    </li>
                </ul>
            </li>

        </ul>
    </div>
</nav>
<!--end::Header-->
