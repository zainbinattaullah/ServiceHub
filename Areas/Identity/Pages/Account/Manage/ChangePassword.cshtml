@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<!-- Content Header -->
<div class="manage-content-header">
    <div class="header-icon">
        <i class="fas fa-key"></i>
    </div>
    <div>
        <h5>Change Password</h5>
        <p>Update your password to keep your account secure</p>
    </div>
</div>

<!-- Content Body -->
<div class="manage-content-body">
    <partial name="_StatusMessage" for="StatusMessage" />

    <form id="change-password-form" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        <!-- Security notice -->
        <div style="background:linear-gradient(135deg,#eff6ff,#dbeafe); border:1px solid #bfdbfe;
                    border-radius:12px; padding:14px 18px; margin-bottom:24px;
                    display:flex; align-items:center; gap:12px;">
            <div style="width:38px; height:38px; background:#3b82f6; border-radius:10px;
                        display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                <i class="fas fa-shield-alt" style="color:#fff; font-size:16px;"></i>
            </div>
            <div>
                <div style="font-size:13px; font-weight:700; color:#1e40af;">Security Tip</div>
                <div style="font-size:12px; color:#3b82f6;">
                    Use a strong password with at least 8 characters, including uppercase, lowercase, numbers, and symbols.
                </div>
            </div>
        </div>

        <!-- Current Password -->
        <div class="manage-field">
            <label>Current Password</label>
            <div class="input-wrapper">
                <i class="fas fa-lock input-icon"></i>
                <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password"
                       aria-required="true" placeholder="Enter current password"
                       style="padding-left:44px; padding-right:44px;" />
                <button type="button" class="toggle-pw" title="Show password">
                    <i class="fas fa-eye"></i>
                </button>
            </div>
            <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
        </div>

        <!-- New Password -->
        <div class="manage-field">
            <label>New Password</label>
            <div class="input-wrapper">
                <i class="fas fa-key input-icon"></i>
                <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password"
                       aria-required="true" placeholder="Enter new password"
                       style="padding-left:44px; padding-right:44px;"
                       id="newPwField" />
                <button type="button" class="toggle-pw" title="Show password">
                    <i class="fas fa-eye"></i>
                </button>
            </div>
            <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
            <!-- Strength indicator -->
            <div id="pwStrengthBar" style="margin-top:8px; display:none;">
                <div style="display:flex; gap:4px; margin-bottom:4px;">
                    <div class="pw-bar" style="flex:1; height:4px; border-radius:2px; background:#e2e8f0;"></div>
                    <div class="pw-bar" style="flex:1; height:4px; border-radius:2px; background:#e2e8f0;"></div>
                    <div class="pw-bar" style="flex:1; height:4px; border-radius:2px; background:#e2e8f0;"></div>
                    <div class="pw-bar" style="flex:1; height:4px; border-radius:2px; background:#e2e8f0;"></div>
                </div>
                <div id="pwStrengthText" style="font-size:11px; font-weight:600; color:#94a3b8;"></div>
            </div>
        </div>

        <!-- Confirm Password -->
        <div class="manage-field">
            <label>Confirm New Password</label>
            <div class="input-wrapper">
                <i class="fas fa-check-double input-icon"></i>
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password"
                       aria-required="true" placeholder="Re-enter new password"
                       style="padding-left:44px; padding-right:44px;" />
                <button type="button" class="toggle-pw" title="Show password">
                    <i class="fas fa-eye"></i>
                </button>
            </div>
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
        </div>

        <!-- Submit -->
        <button type="submit" class="manage-submit">
            <i class="fas fa-key"></i> Update Password
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Password strength meter
        $('#newPwField').on('input', function () {
            var pw   = $(this).val();
            var bars = $('.pw-bar');
            var text = $('#pwStrengthText');
            var wrap = $('#pwStrengthBar');

            if (pw.length === 0) { wrap.hide(); return; }
            wrap.show();

            var score = 0;
            if (pw.length >= 8)             score++;
            if (/[A-Z]/.test(pw))           score++;
            if (/[0-9]/.test(pw))           score++;
            if (/[^A-Za-z0-9]/.test(pw))    score++;

            var colors = ['#ef4444', '#f97316', '#eab308', '#22c55e'];
            var labels = ['Weak', 'Fair', 'Good', 'Strong'];

            bars.each(function (i) {
                $(this).css('background', i < score ? colors[score - 1] : '#e2e8f0');
            });
            text.text(labels[score - 1] || '').css('color', colors[score - 1] || '#94a3b8');
        });
    </script>
}
