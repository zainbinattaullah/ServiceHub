@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Password Reset Successful";
}

<div style="text-align:center; padding:20px 0;">
    <div style="width:80px; height:80px; background:linear-gradient(135deg,#10b981,#059669);
                border-radius:50%; margin:0 auto 20px; display:flex; align-items:center;
                justify-content:center; box-shadow:0 8px 24px rgba(16,185,129,0.3);">
        <i class="fas fa-check" style="font-size:36px; color:#fff;"></i>
    </div>
    <h4 style="font-weight:700; color:#1e293b; margin:0 0 10px;">Password Reset Successful</h4>
    <p style="font-size:14px; color:#64748b; margin:0 0 24px; max-width:360px; display:inline-block;">
        Your password has been reset successfully. You can now sign in with your new password.
    </p>
    <div>
        <a href="/Identity/Account/Login"
           style="display:inline-block; padding:10px 28px; background:linear-gradient(135deg,#4f8fea,#2d5a96);
                  color:#fff; border-radius:10px; font-weight:600; text-decoration:none; font-size:14px;">
            <i class="fas fa-sign-in-alt me-1"></i> Sign In
        </a>
    </div>
</div>
