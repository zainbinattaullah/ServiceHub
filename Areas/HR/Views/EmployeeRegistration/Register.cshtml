@model ServiceHub.Models.EmployeeViewModel

@{
    ViewData["Title"] = "Register Employee";
    ViewData["PageIcon"] = "fas fa-user-plus";
}

<div class="row">
    <div class="col-lg-8">
        <div id="transferWindowInfo" class="mt-2"></div>

        <div class="card">
            <div class="card-body">

                @if (ViewBag.Message != null)
                {
                    <div class="alert alert-success"><i class="fas fa-check-circle me-1"></i>@ViewBag.Message</div>
                }
                @if (ViewBag.Alert != null)
                {
                    <div class="alert alert-danger"><i class="fas fa-exclamation-circle me-1"></i>@ViewBag.Alert</div>
                }

                @using (Html.BeginForm("Register", "EmployeeRegistration", new { area = "HR" }, FormMethod.Post, null, new { @class = "mt-3" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(false, "", new { @class = "text-danger" })

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">@Html.LabelFor(m => m.EmployeeCode)</label>
                            @Html.TextBoxFor(m => m.EmployeeCode, new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.EmployeeCode, "", new { @class = "text-danger" })
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Html.LabelFor(m => m.EmployeeName)</label>
                            @Html.TextBoxFor(m => m.EmployeeName, new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.EmployeeName, "", new { @class = "text-danger" })
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Html.LabelFor(m => m.MachineIP)</label>
                            @Html.DropDownListFor(m => m.MachineIP, Model.MachineIPs ?? Enumerable.Empty<SelectListItem>(), "-- Select Machine IP --", new { @class = "form-select", id = "machineIpSelect" })
                            @Html.ValidationMessageFor(m => m.MachineIP, "", new { @class = "text-danger" })
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Html.LabelFor(m => m.Privilege)</label>
                            @if (Model.PrivilegeOptions != null && Model.PrivilegeOptions.Any())
                            {
                                @Html.DropDownListFor(m => m.Privilege, Model.PrivilegeOptions, "-- Select Privilege --", new { @class = "form-select" })
                            }
                            else
                            {
                                @Html.TextBoxFor(m => m.Privilege, new { @class = "form-control" })
                            }
                            @Html.ValidationMessageFor(m => m.Privilege, "", new { @class = "text-danger" })
                        </div>
                        <div class="col-12">
                            <button id="registerBtn" type="submit" class="btn btn-gradient" @(ViewBag.IsTransferWindowOpen == false ? "disabled" : "")>
                                <i class="fas fa-user-plus me-1"></i> Register
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link href="~/css/select2.css" rel="stylesheet" />
    <script src="~/js/select2.js"></script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            $('#machineIpSelect').select2({
                placeholder: '-- Select Machine IP --',
                allowClear: true,
                width: '100%'
            });

            function checkTransferWindow() {
                $.get('/HR/TransferEmployee_API/CheckTransferWindow', function(data) {
                    var isOpen = !!data.isOpen;
                    $('#registerBtn').prop('disabled', !isOpen);
                    if (!isOpen) {
                        $('#transferWindowInfo').html('<div class="alert alert-danger"><i class="fas fa-clock me-1"></i>' + data.message + '</div>');
                    } else {
                        $('#transferWindowInfo').empty();
                    }
                }).always(function() {
                    setTimeout(checkTransferWindow, 30000);
                });
            }

            checkTransferWindow();
        });
    </script>
}
