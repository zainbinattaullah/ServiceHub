@model ServiceHub.Areas.HR.Models.AttendanceMachine

@{
    ViewData["Title"] = "Create Attendance Machine";
    ViewData["PageIcon"] = "fas fa-plus-circle";
}

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header d-flex align-items-center">
                <a class="btn btn-sm btn-gradient-success" asp-action="Index">
                    <i class="fas fa-list me-1"></i> Back to List
                </a>
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label">Name</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IpAddress" class="form-label">IP Address</label>
                            <input asp-for="IpAddress" class="form-control" />
                            <span asp-validation-for="IpAddress" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DeviceModel" class="form-label">Device Model</label>
                            <input asp-for="DeviceModel" class="form-control" />
                            <span asp-validation-for="DeviceModel" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Port" class="form-label">Port</label>
                            <input asp-for="Port" type="number" min="1" max="65535" class="form-control" />
                            <span asp-validation-for="Port" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Location" class="form-label">Location</label>
                            <input asp-for="Location" class="form-control" />
                            <span asp-validation-for="Location" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 d-flex align-items-center gap-4 pt-4">
                            <div class="form-check form-switch">
                                <input type="checkbox" asp-for="IsActive" class="form-check-input" />
                                <label asp-for="IsActive" class="form-check-label">Active</label>
                            </div>
                            <div class="form-check form-switch">
                                <input type="checkbox" asp-for="IsFetchAll" class="form-check-input" />
                                <label asp-for="IsFetchAll" class="form-check-label">Fetch All Records</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-gradient">
                                <i class="fas fa-save me-1"></i> Create
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
