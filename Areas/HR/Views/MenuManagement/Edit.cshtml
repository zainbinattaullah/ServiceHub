@using ServiceHub.Areas.HR.Models
@model MenuItem
@{
    ViewData["Title"] = "Edit Menu Item";
    ViewData["PageIcon"] = "fas fa-pencil-alt";
    var parents = ViewBag.Parents as List<MenuItem> ?? new();
}

<div class="row">
    <div class="col-lg-8">
        <div class="card" style="max-width:680px">
            <div class="card-header d-flex justify-content-end align-items-center">
                <a asp-action="Index" class="btn btn-sm btn-gradient-success">
                    <i class="fas fa-list me-1"></i> Back to List
                </a>
            </div>
            <div class="card-body">
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    @{
                        var editVd = new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData);
                        editVd["Parents"] = parents;
                    }
                    @await Html.PartialAsync("_MenuItemForm", Model, editVd)
                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-gradient">
                            <i class="fas fa-save me-1"></i> Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
