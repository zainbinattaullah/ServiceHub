@using ServiceHub.Areas.HR.Models
@model MenuItem
@{
    var parents = ViewData["Parents"] as List<MenuItem> ?? new();
}

<div class="row g-3">
    <div class="col-12">
        <label asp-for="Name" class="form-label fw-semibold"></label>
        <input asp-for="Name" class="form-control" placeholder="e.g. Attendance Machine" />
        <span asp-validation-for="Name" class="text-danger small"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Icon" class="form-label fw-semibold">
            Icon <small class="text-muted">(Font Awesome class)</small>
        </label>
        <div class="input-group">
            <span class="input-group-text" id="iconPreview">
                <i id="iconPreviewEl" class="@(Model.Icon ?? "fas fa-circle")"></i>
            </span>
            <input asp-for="Icon" class="form-control" placeholder="fas fa-home"
                   oninput="document.getElementById('iconPreviewEl').className=this.value||'fas fa-circle'" />
        </div>
        <small class="text-muted">
            Browse icons at
            <a href="https://fontawesome.com/icons?d=gallery&s=solid&m=free" target="_blank">fontawesome.com</a>
        </small>
    </div>

    <div class="col-md-6">
        <label asp-for="ParentId" class="form-label fw-semibold">Parent Item</label>
        <select asp-for="ParentId" class="form-select">
            <option value="">--- None (top-level group) ---</option>
            @foreach (var p in parents)
            {
                <option value="@p.Id">@p.Name</option>
            }
        </select>
    </div>

    <div class="col-12">
        <div class="card bg-light border-0">
            <div class="card-body pb-1">
                <p class="mb-2 fw-semibold text-muted small text-uppercase">
                    Route (recommended) --- OR --- direct URL
                </p>
                <div class="row g-2">
                    <div class="col-md-4">
                        <label asp-for="Area" class="form-label small">Area</label>
                        <input asp-for="Area" class="form-control form-control-sm" placeholder="HR" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Controller" class="form-label small">Controller</label>
                        <input asp-for="Controller" class="form-control form-control-sm"
                               placeholder="AttendanceMachine" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Action" class="form-label small">Action</label>
                        <input asp-for="Action" class="form-control form-control-sm" placeholder="Index" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Url" class="form-label small">Direct URL (overrides route)</label>
                        <input asp-for="Url" class="form-control form-control-sm"
                               placeholder="/HR/AttendanceMachine/Index" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <label asp-for="OrderIndex" class="form-label fw-semibold">Display Order</label>
        <input asp-for="OrderIndex" type="number" class="form-control" min="0" />
    </div>

    <div class="col-md-4 d-flex align-items-end">
        <div class="form-check form-switch mb-2">
            <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
            <label asp-for="IsActive" class="form-check-label fw-semibold">Active</label>
        </div>
    </div>
</div>
