@using Microsoft.AspNetCore.Identity
@{
    ViewData["Title"] = "Role Assignment";
    ViewData["PageIcon"] = "fas fa-shield-alt";
    var item     = ViewBag.MenuItem as ServiceHub.Areas.HR.Models.MenuItem;
    var allRoles = ViewBag.AllRoles as List<IdentityRole> ?? new();
    var assigned = ViewBag.Assigned as HashSet<string> ?? new();
}

<div class="row">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center gap-2 mb-3 p-2 rounded" style="background:var(--sh-card-bg, #f8f9fa); border:1px solid var(--sh-border, #dee2e6);">
                    <i class="@(item?.Icon ?? "fas fa-circle") me-1" style="color:var(--sh-primary)"></i>
                    <strong>@item?.Name</strong>
                </div>
                <small class="text-muted d-block mb-3">
                    Leave ALL boxes unchecked to make this item visible to every logged-in user.
                    Check specific roles to restrict access.
                </small>

                <form asp-action="RoleAssignment" asp-route-id="@item?.Id" method="post">
                    @Html.AntiForgeryToken()

                    @if (!allRoles.Any())
                    {
                        <div class="alert alert-info"><i class="fas fa-info-circle me-1"></i>No roles found. Create roles first.</div>
                    }
                    else
                    {
                        <div class="row g-2">
                            @foreach (var role in allRoles)
                            {
                                bool isChecked = assigned.Contains(role.Id);
                                <div class="col-12">
                                    <div class="form-check form-switch p-3 border rounded
                                        @(isChecked ? "border-primary bg-primary bg-opacity-10" : "")">
                                        <input class="form-check-input" type="checkbox"
                                               name="selectedRoleIds" value="@role.Id"
                                               id="role_@role.Id"
                                               @(isChecked ? "checked" : "") />
                                        <label class="form-check-label fw-semibold ms-2"
                                               for="role_@role.Id">
                                            <i class="fas fa-user-tag me-1"></i>
                                            @role.Name
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-gradient-warning">
                            <i class="fas fa-save me-1"></i> Save Role Assignment
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
