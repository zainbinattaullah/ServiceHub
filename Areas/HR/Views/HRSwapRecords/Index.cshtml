@model IEnumerable<HRSwapRecord>

@{
    ViewData["Title"] = "Attendance Swap Records";
    ViewData["PageIcon"] = "fas fa-exchange-alt";
}

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-body">
                <div class="row g-3 mb-3 align-items-end">
                    <div class="col-lg-3 col-md-3 col-sm-6">
                        <label for="ipFilter" class="form-label">IP Address</label>
                        <select id="ipFilter" class="form-select">
                            <option value="">All</option>
                        </select>
                    </div>
                    <div class="col-lg-3 col-md-2 col-sm-6">
                        <label for="startDate" class="form-label">Start Date</label>
                        <input type="date" id="startDate" class="form-control" />
                    </div>
                    <div class="col-lg-3 col-md-2 col-sm-6">
                        <label for="endDate" class="form-label">End Date</label>
                        <input type="date" id="endDate" class="form-control" />
                    </div>
                </div>

                <table id="connectionLogsTable" class="table table-striped table-bordered table-hover" style="width:100%">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Emp #</th>
                            <th>Emp Name</th>
                            <th>Swap Time</th>
                            <th>Shift In</th>
                            <th>Shift Out</th>
                            <th>Creation Date</th>
                            <th>Machine IP</th>
                            <th>Machine Port</th>
                            <th>Machine ID</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link href="~/css/select2.css" rel="stylesheet" />
    <script src="~/js/select2.js"></script>
    <script>
        $(document).ready(function () {
            $('#ipFilter').select2({
                placeholder: "Select IP",
                allowClear: true
            });
            $.ajax({
                url: "/HR/HRSwapRecords/GetMachineIPs",
                type: "GET",
                success: function (data) {
                    var ipFilter = $('#ipFilter');
                    data.forEach(function (ip) {
                        ipFilter.append($('<option>', { value: ip, text: ip }));
                    });
                }
            });

            var table = $('#connectionLogsTable').DataTable({
                processing: true,
                serverSide: true,
                ajax: {
                    url: '/HR/HRSwapRecords/GetAttendanceRecords',
                    type: 'POST',
                    data: function (d) {
                        d.ipAddress = $('#ipFilter').val();
                        d.startDate = $('#startDate').val();
                        d.endDate = $('#endDate').val();
                    }
                },
                columns: [
                    { data: 'id' },
                    { data: 'emp_No' },
                    { data: 'emp_Name' },
                    { data: 'swap_Time' },
                    {
                        data: 'shift_In',
                        render: function (data) {
                            return data ? '<span class="badge bg-success">Yes</span>' : '<span class="badge bg-danger">No</span>';
                        }
                    },
                    {
                        data: 'shift_Out',
                        render: function (data) {
                            return data ? '<span class="badge bg-success">Yes</span>' : '<span class="badge bg-danger">No</span>';
                        }
                    },
                    { data: 'creation_Date' },
                    { data: 'machine_IP' },
                    { data: 'machine_Port' },
                    { data: 'machineId' }
                ],
                dom: '<"row"<"col-sm-2"l><"col-sm-10"Bf>>' +
                    '<"row"<"col-sm-12"tr>>' +
                    '<"row"<"col-sm-5"i><"col-sm-7"p>>',
                buttons: [
                    { extend: 'copy',  text: '<i class="fas fa-copy"></i> Copy',  className: 'btn btn-dt-primary btn-sm' },
                    {
                        text: '<i class="fas fa-file-excel"></i> Export All (Excel)',
                        className: 'btn btn-dt-success btn-sm',
                        action: function (e, dt, button, config) {
                            var ipAddress = $('#ipFilter').val();
                            var startDate = $('#startDate').val();
                            var endDate = $('#endDate').val();
                            window.location.href = '/HR/HRSwapRecords/ExportAttendanceRecords' +
                                '?ipAddress=' + encodeURIComponent(ipAddress || '') +
                                '&startDate=' + encodeURIComponent(startDate || '') +
                                '&endDate=' + encodeURIComponent(endDate || '');
                        }
                    },
                    { extend: 'pdf',   text: '<i class="fas fa-file-pdf"></i> PDF',   className: 'btn btn-dt-danger btn-sm' },
                    { extend: 'print', text: '<i class="fas fa-print"></i> Print', className: 'btn btn-dt-warning btn-sm' }
                ]
            });

            $('#ipFilter, #startDate, #endDate').on('change', function () {
                table.ajax.reload();
            });
        });
    </script>
}
