@model ServiceHub.Areas.HR.Models.MachineLockPageViewModel
@{
    ViewData["Title"] = "Machine Lock / Unlock Dashboard";
    ViewData["PageIcon"] = "fas fa-lock";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/css/select2.css" rel="stylesheet" />
<style>
    :root {
        --navy:      #1e3a5f;
        --locked:    #dc3545;
        --locked-bg: #fce4e8;
        --unlock:    #198754;
        --unlock-bg: #d4f5e2;
        --online:    #20c763;
        --offline:   #e53e5a;
        --pending:   #fd7e14;
    }

    /* Summary cards */
    .lock-cards {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 22px;
    }

    .lock-card {
        background: var(--sh-surface, #fff);
        border-radius: 10px;
        box-shadow: var(--sh-shadow);
        padding: 18px 22px;
        display: flex;
        align-items: center;
        gap: 16px;
        border-left: 5px solid var(--navy);
    }

    .lock-card.c-total   { border-left-color: var(--navy); }
    .lock-card.c-locked  { border-left-color: var(--locked); }
    .lock-card.c-unlock  { border-left-color: var(--unlock); }
    .lock-card.c-pending { border-left-color: var(--pending); }

    .lc-icon {
        width: 48px; height: 48px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px; flex-shrink: 0;
    }

    .c-total   .lc-icon { background: #e8eef8; color: var(--navy); }
    .c-locked  .lc-icon { background: var(--locked-bg); color: var(--locked); }
    .c-unlock  .lc-icon { background: var(--unlock-bg); color: var(--unlock); }
    .c-pending .lc-icon { background: #fff3cd; color: var(--pending); }

    .lc-label {
        font-size: 11px; font-weight: 700; text-transform: uppercase;
        letter-spacing: .06em; color: #6b7a94; margin-bottom: 3px;
    }

    .lc-value {
        font-size: 30px; font-weight: 800; color: var(--sh-text, #1a2535);
        font-family: 'Courier New', monospace;
    }

    /* Filter bar */
    .filter-bar {
        background: var(--sh-surface, #fff); border-radius: 10px;
        box-shadow: var(--sh-shadow); padding: 14px 18px;
        margin-bottom: 18px; display: flex; gap: 10px; flex-wrap: wrap;
        align-items: flex-end;
    }

    .fg { display: flex; flex-direction: column; gap: 3px; min-width: 140px; }

    .fg label {
        font-size: 11px; font-weight: 700; text-transform: uppercase;
        letter-spacing: .05em; color: var(--sh-text-muted, #6b7a94);
    }

    .fg select, .fg input[type="text"] {
        border: 1.5px solid var(--sh-border); border-radius: 6px;
        padding: 5px 9px; font-size: 13px; background: var(--sh-surface, #f7f9fc);
        color: var(--sh-text); outline: none; height: 32px; transition: border-color .15s;
    }

    .fg select:focus, .fg input:focus {
        border-color: var(--sh-primary); background: var(--sh-surface);
    }

    /* Bulk action bar */
    .bulk-bar {
        background: #fff8e1; border: 1.5px solid #ffc107;
        border-radius: 8px; padding: 10px 18px;
        margin-bottom: 16px; display: none;
        align-items: center; gap: 12px; flex-wrap: wrap;
    }

    .bulk-bar.visible { display: flex; }
    .bulk-count { font-weight: 700; color: #856404; font-size: 14px; }

    /* Table card */
    .table-card {
        background: var(--sh-surface, #fff); border-radius: 10px;
        box-shadow: var(--sh-shadow); overflow: hidden;
    }

    .table-card-header {
        background: var(--sh-primary, #1e3a5f); color: #fff;
        padding: 13px 20px; display: flex;
        align-items: center; justify-content: space-between;
        flex-wrap: wrap; gap: 8px;
    }

    .table-card-header h5 { margin: 0; font-size: 15px; font-weight: 700; }
    .table-card-body { padding: 16px; }

    /* Badges */
    .badge-locked   { background: var(--locked-bg); color: #b91c30;
        padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; }
    .badge-unlocked { background: var(--unlock-bg); color: #138a4a;
        padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; }
    .badge-pending  { background: #fff3cd; color: #856404;
        padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; }

    .badge-online  { background: #d4f5e2; color: #138a4a;
        padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; }
    .badge-offline { background: var(--locked-bg); color: #b91c30;
        padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; }

    .dot-pulse {
        width: 7px; height: 7px; border-radius: 50%;
        display: inline-block; margin-right: 4px;
        background: var(--online); animation: pulse-g 2s infinite;
    }

    @@keyframes pulse-g {
        0%   { box-shadow: 0 0 0 0 rgba(32,199,99,.5); }
        70%  { box-shadow: 0 0 0 7px rgba(32,199,99,0); }
        100% { box-shadow: 0 0 0 0 rgba(32,199,99,0); }
    }

    /* Action buttons inside table */
    .btn-lock   { background: var(--locked); color:#fff; border:none;
        border-radius:5px; padding: 3px 10px; font-size:12px; cursor:pointer; }
    .btn-unlock { background: var(--unlock); color:#fff; border:none;
        border-radius:5px; padding: 3px 10px; font-size:12px; cursor:pointer; }
    .btn-lock:hover   { background: #b02a37; }
    .btn-unlock:hover { background: #146c43; }
    .btn-history { background: #6c757d; color:#fff; border:none;
        border-radius:5px; padding: 3px 8px; font-size:11px; cursor:pointer; }
    .btn-history:hover { background: #5a6268; }

    .btn-refresh {
        background: transparent; border: 1.5px solid rgba(255,255,255,.5);
        color: #fff; border-radius: 6px; padding: 4px 14px;
        font-size: 12px; cursor: pointer; transition: all .15s;
    }
    .btn-refresh:hover    { background: rgba(255,255,255,.15); }
    @@keyframes spin-it   { to { transform: rotate(360deg); } }
    .btn-refresh.spinning i { animation: spin-it .7s linear infinite; }

    #lockTable thead th {
        background: var(--sh-surface-alt, #f0f4fa); color: var(--sh-primary);
        font-size: 11px; font-weight: 700; text-transform: uppercase;
        letter-spacing: .04em; border-bottom: 2px solid var(--sh-border);
        white-space: nowrap;
    }

    #lockTable tbody tr:hover { background: var(--sh-surface-alt, #f7f9fd); }

    /* History modal table */
    .hist-table th { background: #1e3a5f; color:#fff; font-size:12px; }
    .hist-table td { font-size:12px; }

    @@media (max-width: 992px) {
        .lock-cards { grid-template-columns: repeat(2,1fr); }
    }
    @@media (max-width: 576px) {
        .lock-cards { grid-template-columns: 1fr; }
    }
</style>

<div class="container-fluid" style="padding:20px 16px;">

    <!-- Summary Cards -->
    <div class="lock-cards">
        <div class="lock-card c-total">
            <div class="lc-icon"><i class="fas fa-server"></i></div>
            <div><div class="lc-label">Total Machines</div><div class="lc-value" id="cntTotal">--</div></div>
        </div>
        <div class="lock-card c-locked">
            <div class="lc-icon"><i class="fas fa-lock"></i></div>
            <div><div class="lc-label">Locked</div><div class="lc-value" id="cntLocked">--</div></div>
        </div>
        <div class="lock-card c-unlock">
            <div class="lc-icon"><i class="fas fa-lock-open"></i></div>
            <div><div class="lc-label">Unlocked</div><div class="lc-value" id="cntUnlocked">--</div></div>
        </div>
        <div class="lock-card c-pending">
            <div class="lc-icon"><i class="fas fa-clock"></i></div>
            <div><div class="lc-label">Pending</div><div class="lc-value" id="cntPending">--</div></div>
        </div>
    </div>

    <!-- Filter Bar -->
    <div class="filter-bar">
        <div class="fg">
            <label>Branch / Location</label>
            <select id="fLoc">
                <option value="">All Locations</option>
                @foreach (var s in Model.Stores)
                {
                    <option value="@s.StoreCode">@s.StoreName (@s.StoreCode)</option>
                }
            </select>
        </div>
        <div class="fg">
            <label>Area</label>
            <select id="fArea">
                <option value="">All Areas</option>
                @foreach (var a in Model.Areas)
                {
                    <option value="@a">@a</option>
                }
            </select>
        </div>
        <div class="fg">
            <label>Region</label>
            <select id="fRegion">
                <option value="">All Regions</option>
                @foreach (var r in Model.Regions)
                {
                    <option value="@r">@r</option>
                }
            </select>
        </div>
        <div class="fg">
            <label>Machine</label>
            <input type="text" id="fMachine" placeholder="Name or ID..." />
        </div>
        <div class="fg">
            <label>Lock Status</label>
            <select id="fLock">
                <option value="">All</option>
                <option value="Locked">Locked</option>
                <option value="Unlocked">Unlocked</option>
            </select>
        </div>
        <div class="fg">
            <label>Connectivity</label>
            <select id="fConn">
                <option value="">All</option>
                <option value="Online">Online</option>
                <option value="Offline">Offline</option>
            </select>
        </div>
        <div class="fg" style="flex-direction:row;align-items:flex-end;gap:6px;min-width:auto;">
            <button class="btn btn-primary btn-sm" id="btnApply" style="height:32px;padding:0 14px;">
                <i class="fas fa-filter"></i> Apply
            </button>
            <button class="btn btn-outline-secondary btn-sm" id="btnClear" style="height:32px;padding:0 12px;">
                <i class="fas fa-times"></i> Clear
            </button>
        </div>
    </div>

    <!-- Bulk Action Bar -->
    <div class="bulk-bar" id="bulkBar">
        <span class="bulk-count"><i class="fas fa-check-square"></i> <span id="selectedCount">0</span> machine(s) selected</span>
        <button class="btn btn-danger btn-sm" id="btnBulkLock">
            <i class="fas fa-lock"></i> Lock Selected
        </button>
        <button class="btn btn-success btn-sm" id="btnBulkUnlock">
            <i class="fas fa-lock-open"></i> Unlock Selected
        </button>
        <button class="btn btn-outline-secondary btn-sm" id="btnClearSelection">
            <i class="fas fa-times"></i> Clear Selection
        </button>

        <div style="margin-left:auto; display:flex; gap:6px; flex-wrap:wrap;">
            <select id="bulkByArea" class="form-select form-select-sm" style="width:160px;">
                <option value="">Lock/Unlock by Area...</option>
                @foreach (var a in Model.Areas)
                {
                    <option value="@a">@a</option>
                }
            </select>
            <button class="btn btn-danger btn-sm" id="btnAreaLock">
                <i class="fas fa-lock"></i> Lock Area
            </button>
            <button class="btn btn-success btn-sm" id="btnAreaUnlock">
                <i class="fas fa-lock-open"></i> Unlock Area
            </button>
        </div>
    </div>

    <!-- Table Card -->
    <div class="table-card">
        <div class="table-card-header">
            <h5><i class="fas fa-shield-alt" style="margin-right:8px;"></i>Machine Lock / Unlock Dashboard</h5>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                <span style="font-size:11px;color:rgba(255,255,255,.7);">
                    <span class="dot-pulse"></span>Auto-refresh 30s
                </span>
                <button class="btn-refresh" id="btnRefresh">
                    <i class="fas fa-sync-alt"></i> Refresh
                </button>
            </div>
        </div>
        <div class="table-card-body">
            <table id="lockTable" class="table table-striped table-bordered table-hover" style="width:100%">
                <thead>
                    <tr>
                        <th style="width:36px;">
                            <input type="checkbox" id="chkAll" title="Select all" />
                        </th>
                        <th>Machine</th>
                        <th>Branch / Store</th>
                        <th>Area</th>
                        <th>Region</th>
                        <th>Lock Status</th>
                        <th>Connectivity</th>
                        <th>Last Sync</th>
                        <th>Last Action</th>
                        <th>Action By</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<!-- ============================================================
     CONFIRMATION MODAL
============================================================ -->
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" id="confirmModalHeader">
                <h5 class="modal-title" id="confirmModalTitle">Confirm Action</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="confirmModalBody" style="font-size:15px;"></p>
                <div class="mb-3">
                    <label style="font-size:12px;font-weight:600;color:#6b7a94;">Notes (optional)</label>
                    <textarea id="actionNotes" class="form-control form-control-sm" rows="2"
                              placeholder="Reason for this action..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn" id="btnConfirmAction">Confirm</button>
            </div>
        </div>
    </div>
</div>

<!-- ============================================================
     HISTORY MODAL
============================================================ -->
<div class="modal fade" id="historyModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header" style="background:var(--navy);color:#fff;">
                <h5 class="modal-title"><i class="fas fa-history me-2"></i>Lock/Unlock History</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding:0;">
                <div id="historyContent" style="padding:16px;">
                    <div class="text-center text-muted py-3">Loading...</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ============================================================
     RESULT TOAST
============================================================ -->
<div style="position:fixed;bottom:24px;right:24px;z-index:9999;">
    <div id="resultToast" class="toast align-items-center border-0" role="alert" aria-live="assertive">
        <div class="d-flex">
            <div class="toast-body" id="toastBody" style="font-size:14px;font-weight:600;"></div>
            <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/select2.js"></script>
<script>
$(function () {

    if (typeof $.fn.DataTable === 'undefined') {
        console.error('DataTables not loaded.');
        return;
    }

    // Initialize Select2 on filter dropdowns
    $('#fLoc, #fArea, #fRegion, #fLock, #fConn').select2({
        width: '100%',
        minimumResultsForSearch: 5
    });

    // ----------------------------------------------------------------
    //  State
    // ----------------------------------------------------------------
    var selectedMachines = {};   // { machineId: { machineName, action } }
    var pendingPoll      = {};   // { logId: machineId } — polling for completion
    var confirmAction    = null; // { machineIds:[], action, label }
    var autoRefreshTimer = null;

    // ----------------------------------------------------------------
    //  Summary card animation
    // ----------------------------------------------------------------
    function animateCount(id, target) {
        var el = document.getElementById(id);
        if (!el) return;
        var cur = parseInt(el.textContent, 10) || 0;
        if (cur === target) { el.textContent = target; return; }
        var step = Math.max(1, Math.ceil(Math.abs(target - cur) / 10));
        var dir  = target > cur ? 1 : -1;
        var t    = setInterval(function () {
            cur += dir * step;
            if ((dir===1 && cur>=target)||(dir===-1 && cur<=target)) {
                cur = target; clearInterval(t);
            }
            el.textContent = cur;
        }, 30);
    }

    // ----------------------------------------------------------------
    //  Renderers
    // ----------------------------------------------------------------
    function renderLockStatus(row) {
        if (row.hasPending) {
            return '<span class="badge-pending"><i class="fas fa-spinner fa-spin me-1"></i>'
                 + row.pendingAction + 'ing...</span>';
        }
        if (row.isLocked) {
            return '<span class="badge-locked"><i class="fas fa-lock me-1"></i>Locked</span>';
        }
        return '<span class="badge-unlocked"><i class="fas fa-lock-open me-1"></i>Unlocked</span>';
    }

    function renderConn(isOnline) {
        if (isOnline)
            return '<span class="badge-online"><span class="dot-pulse"></span>Online</span>';
        return '<span class="badge-offline"><i class="fas fa-times-circle me-1"></i>Offline</span>';
    }

    function renderActions(row) {
        var lockBtn   = row.isLocked
            ? ''
            : '<button class="btn-lock me-1" onclick="singleAction(' + row.machineId + ',\'Lock\',\'' + escHtml(row.machineName) + '\')">'
              + '<i class="fas fa-lock"></i> Lock</button>';

        var unlockBtn = row.isLocked
            ? '<button class="btn-unlock me-1" onclick="singleAction(' + row.machineId + ',\'Unlock\',\'' + escHtml(row.machineName) + '\')">'
              + '<i class="fas fa-lock-open"></i> Unlock</button>'
            : '';

        var histBtn = '<button class="btn-history" onclick="showHistory(' + row.machineId + ',\'' + escHtml(row.machineName) + '\')">'
                    + '<i class="fas fa-history"></i></button>';

        return lockBtn + unlockBtn + histBtn;
    }

    function escHtml(str) {
        return (str || '').replace(/'/g, "\\'");
    }

    function renderCheckbox(row) {
        var chk = selectedMachines[row.machineId] ? 'checked' : '';
        return '<input type="checkbox" class="row-chk" data-id="' + row.machineId
             + '" data-name="' + escHtml(row.machineName) + '" ' + chk + ' />';
    }

    // ----------------------------------------------------------------
    //  DataTable
    // ----------------------------------------------------------------
    var table = $('#lockTable').DataTable({
        processing : true,
        serverSide : true,
        ajax: {
            url  : '/HR/MachineLock/GetDashboardData',
            type : 'POST',
            data : function (d) {
                d.filterLocation = $('#fLoc').val();
                d.filterArea     = $('#fArea').val();
                d.filterRegion   = $('#fRegion').val();
                d.filterMachine  = $('#fMachine').val();
                d.filterLock     = $('#fLock').val();
                d.filterConn     = $('#fConn').val();
                return d;
            },
            dataSrc: function (json) {
                // Update summary cards
                var rows     = json.data || [];
                var total    = json.recordsTotal || 0;
                var locked   = rows.filter(r => r.isLocked).length;
                var unlocked = rows.filter(r => !r.isLocked).length;
                var pending  = rows.filter(r => r.hasPending).length;
                animateCount('cntTotal',    total);
                animateCount('cntLocked',   locked);
                animateCount('cntUnlocked', unlocked);
                animateCount('cntPending',  pending);
                return rows;
            },
            error: function (xhr, err) { console.error('MachineLock AJAX error:', err); }
        },
        columns: [
            {
                data     : null,
                orderable: false,
                render   : function (data, type, row) { return renderCheckbox(row); },
                width    : '36px'
            },
            {
                data  : 'machineName',
                render: function (data, type, row) {
                    return '<strong>' + (data||'') + '</strong>'
                         + '<br><small style="color:#6b7a94;">' + (row.machineIP||'') + '</small>';
                }
            },
            {
                data  : 'storeName',
                defaultContent: 'N/A',
                render: function (data, type, row) {
                    return (data || 'N/A')
                         + (row.location ? '<br><small style="color:#6b7a94;">' + row.location + '</small>' : '');
                }
            },
            { data: 'area',   defaultContent: '—' },
            { data: 'region', defaultContent: '—' },
            {
                data    : null,
                orderable: false,
                render  : function (data, type, row) { return renderLockStatus(row); }
            },
            {
                data    : 'isOnline',
                orderable: false,
                render  : function (data) { return renderConn(data); }
            },
            { data: 'lastCommLabel',   defaultContent: 'Never' },
            {
                data  : 'lastActionLabel',
                defaultContent: 'Never',
                render: function (data, type, row) {
                    if (!row.lastActionType) return '<span style="color:#aaa;">Never</span>';
                    var icon = row.lastActionType === 'Lock'
                        ? '<i class="fas fa-lock" style="color:var(--locked);"></i>'
                        : '<i class="fas fa-lock-open" style="color:var(--unlock);"></i>';
                    return icon + ' ' + (data || '');
                }
            },
            { data: 'lastActionBy', defaultContent: '—' },
            {
                data    : null,
                orderable: false,
                render  : function (data, type, row) { return renderActions(row); }
            }
        ],
        pageLength : 25,
        lengthMenu : [[10,25,50,100],[10,25,50,100]],
        order      : [[1, 'asc']],
        dom: '<"row"<"col-sm-4"l><"col-sm-8"f>>'
           + '<"row"<"col-sm-12"tr>>'
           + '<"row"<"col-sm-5"i><"col-sm-7"p>>',
        language: {
            processing : '<i class="fas fa-spinner fa-spin"></i> Loading...',
            emptyTable : 'No machines found.'
        }
    });

    // ----------------------------------------------------------------
    //  Checkbox selection
    // ----------------------------------------------------------------
    $('#lockTable').on('change', '.row-chk', function () {
        var id   = parseInt($(this).data('id'), 10);
        var name = $(this).data('name');
        if ($(this).is(':checked')) {
            selectedMachines[id] = { machineName: name };
        } else {
            delete selectedMachines[id];
        }
        updateBulkBar();
    });

    $('#chkAll').on('change', function () {
        var checked = $(this).is(':checked');
        $('#lockTable .row-chk').each(function () {
            $(this).prop('checked', checked);
            var id   = parseInt($(this).data('id'), 10);
            var name = $(this).data('name');
            if (checked) { selectedMachines[id] = { machineName: name }; }
            else         { delete selectedMachines[id]; }
        });
        updateBulkBar();
    });

    function updateBulkBar() {
        var count = Object.keys(selectedMachines).length;
        $('#selectedCount').text(count);
        if (count > 0) { $('#bulkBar').addClass('visible'); }
        else           { $('#bulkBar').removeClass('visible'); }
    }

    $('#btnClearSelection').on('click', function () {
        selectedMachines = {};
        $('#lockTable .row-chk').prop('checked', false);
        $('#chkAll').prop('checked', false);
        updateBulkBar();
    });

    // ----------------------------------------------------------------
    //  Single machine action (called from table buttons)
    // ----------------------------------------------------------------
    window.singleAction = function (machineId, action, machineName) {
        confirmAction = { machineIds: [machineId], action: action, label: machineName };
        openConfirmModal(action, machineName + ' (ID: ' + machineId + ')');
    };

    // ----------------------------------------------------------------
    //  Bulk actions
    // ----------------------------------------------------------------
    $('#btnBulkLock').on('click', function () {
        var ids = Object.keys(selectedMachines).map(Number);
        if (ids.length === 0) return;
        confirmAction = { machineIds: ids, action: 'Lock', label: ids.length + ' selected machine(s)' };
        openConfirmModal('Lock', ids.length + ' selected machine(s)');
    });

    $('#btnBulkUnlock').on('click', function () {
        var ids = Object.keys(selectedMachines).map(Number);
        if (ids.length === 0) return;
        confirmAction = { machineIds: ids, action: 'Unlock', label: ids.length + ' selected machine(s)' };
        openConfirmModal('Unlock', ids.length + ' selected machine(s)');
    });

    // Area-wide lock/unlock
    $('#btnAreaLock').on('click', function () {
        var area = $('#bulkByArea').val();
        if (!area) { showToast('Please select an area first.', 'warning'); return; }
        // Collect machine IDs visible in table for this area
        var ids = collectMachineIdsByArea(area);
        if (ids.length === 0) { showToast('No machines found for area: ' + area, 'warning'); return; }
        confirmAction = { machineIds: ids, action: 'Lock', label: 'all machines in area: ' + area };
        openConfirmModal('Lock', ids.length + ' machine(s) in area "' + area + '"');
    });

    $('#btnAreaUnlock').on('click', function () {
        var area = $('#bulkByArea').val();
        if (!area) { showToast('Please select an area first.', 'warning'); return; }
        var ids = collectMachineIdsByArea(area);
        if (ids.length === 0) { showToast('No machines found for area: ' + area, 'warning'); return; }
        confirmAction = { machineIds: ids, action: 'Unlock', label: 'all machines in area: ' + area };
        openConfirmModal('Unlock', ids.length + ' machine(s) in area "' + area + '"');
    });

    function collectMachineIdsByArea(area) {
        var ids = [];
        table.rows().data().each(function (row) {
            if ((row.area || '') === area) ids.push(row.machineId);
        });
        return ids;
    }

    // ----------------------------------------------------------------
    //  Confirm modal
    // ----------------------------------------------------------------
    function openConfirmModal(action, label) {
        var isLock = action === 'Lock';
        var hdrBg  = isLock ? '#dc3545' : '#198754';
        var icon   = isLock ? 'fa-lock' : 'fa-lock-open';

        $('#confirmModalHeader').css('background', hdrBg).css('color', '#fff');
        $('#confirmModalTitle').html('<i class="fas ' + icon + ' me-2"></i>' + action + ' Confirmation');
        $('#confirmModalBody').html(
            'You are about to <strong>' + action + '</strong> ' + label + '.<br>'
            + '<span style="color:#6b7a94;font-size:13px;">The Windows service will execute this command immediately.</span>'
        );
        $('#btnConfirmAction')
            .removeClass('btn-danger btn-success')
            .addClass(isLock ? 'btn-danger' : 'btn-success')
            .html('<i class="fas ' + icon + ' me-1"></i> Confirm ' + action);

        $('#actionNotes').val('');
        var modal = new bootstrap.Modal(document.getElementById('confirmModal'));
        modal.show();
    }

    $('#btnConfirmAction').on('click', function () {
        if (!confirmAction) return;
        bootstrap.Modal.getInstance(document.getElementById('confirmModal')).hide();
        executeAction(confirmAction.machineIds, confirmAction.action, $('#actionNotes').val());
        confirmAction = null;
    });

    // ----------------------------------------------------------------
    //  Execute action (POST to controller)
    // ----------------------------------------------------------------
    function executeAction(machineIds, action, notes) {
        $.ajax({
            url        : '/HR/MachineLock/ApplyAction',
            type       : 'POST',
            contentType: 'application/json',
            data       : JSON.stringify({ machineIds: machineIds, action: action, notes: notes }),
            headers    : { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
            success    : function (res) {
                if (res.success) {
                    showToast(res.message, 'success');
                    table.ajax.reload(null, false);
                    selectedMachines = {};
                    updateBulkBar();
                } else {
                    showToast(res.message || 'Action failed.', 'danger');
                }
            },
            error: function () {
                showToast('Server error. Please try again.', 'danger');
            }
        });
    }

    // ----------------------------------------------------------------
    //  History modal
    // ----------------------------------------------------------------
    window.showHistory = function (machineId, machineName) {
        $('#historyContent').html('<div class="text-center text-muted py-4"><i class="fas fa-spinner fa-spin fa-2x"></i></div>');
        var modal = new bootstrap.Modal(document.getElementById('historyModal'));
        $('#historyModal .modal-title').html('<i class="fas fa-history me-2"></i>History — ' + machineName);
        modal.show();

        $.get('/HR/MachineLock/GetLockHistory?machineId=' + machineId, function (logs) {
            if (!logs || logs.length === 0) {
                $('#historyContent').html('<div class="text-center text-muted py-3">No history found.</div>');
                return;
            }
            var html = '<table class="table table-sm table-striped table-bordered hist-table mb-0">'
                     + '<thead><tr><th>Action</th><th>Status</th><th>Requested At</th>'
                     + '<th>Executed At</th><th>By</th><th>Notes</th></tr></thead><tbody>';
            logs.forEach(function (l) {
                var isLock  = l.action === 'Lock';
                var icon    = isLock ? '<i class="fas fa-lock text-danger"></i>' : '<i class="fas fa-lock-open text-success"></i>';
                var stBadge = l.status === 'Success'
                    ? '<span class="badge bg-success">Success</span>'
                    : l.status === 'Pending'
                        ? '<span class="badge bg-warning text-dark">Pending</span>'
                        : '<span class="badge bg-danger">Failed</span>';
                html += '<tr>'
                      + '<td>' + icon + ' ' + l.action + '</td>'
                      + '<td>' + stBadge + (l.errorMessage ? '<br><small class="text-danger">' + l.errorMessage + '</small>' : '') + '</td>'
                      + '<td>' + l.requestedAt + '</td>'
                      + '<td>' + l.executedAt  + '</td>'
                      + '<td>' + (l.requestedByUserName || '—') + '</td>'
                      + '<td>' + (l.notes || '—') + '</td>'
                      + '</tr>';
            });
            html += '</tbody></table>';
            $('#historyContent').html(html);
        });
    };

    // ----------------------------------------------------------------
    //  Filters
    // ----------------------------------------------------------------
    $('#btnApply').on('click', function () { table.ajax.reload(); });
    $('#btnClear').on('click', function () {
        $('#fLoc,#fArea,#fRegion,#fLock,#fConn').val('').trigger('change');
        $('#fMachine').val('');
        table.ajax.reload();
    });

    // ----------------------------------------------------------------
    //  Refresh
    // ----------------------------------------------------------------
    $('#btnRefresh').on('click', function () {
        var btn = $(this);
        btn.addClass('spinning').prop('disabled', true);
        table.ajax.reload(function () {
            btn.removeClass('spinning').prop('disabled', false);
        });
    });

    // Auto refresh every 30 seconds
    autoRefreshTimer = setInterval(function () {
        table.ajax.reload(null, false);
    }, 30000);

    // ----------------------------------------------------------------
    //  Toast helper
    // ----------------------------------------------------------------
    function showToast(message, type) {
        var colors = {
            success: '#198754', danger: '#dc3545', warning: '#856404', info: '#0d6efd'
        };
        var bg = colors[type] || colors.info;
        var toast = document.getElementById('resultToast');
        $('#toastBody').text(message);
        toast.style.background = bg;
        toast.style.color      = '#fff';
        var bsToast = new bootstrap.Toast(toast, { delay: 5000 });
        bsToast.show();
    }

    // ----------------------------------------------------------------
    //  Anti-CSRF token for AJAX POST
    // ----------------------------------------------------------------
    $.ajaxSetup({
        beforeSend: function (xhr, settings) {
            if (settings.type === 'POST' && settings.contentType &&
                settings.contentType.indexOf('application/json') !== -1) {
                xhr.setRequestHeader('X-CSRF-TOKEN',
                    $('input[name="__RequestVerificationToken"]').val());
            }
        }
    });

});
</script>

@Html.AntiForgeryToken()
}
