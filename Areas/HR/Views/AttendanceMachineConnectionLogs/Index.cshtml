@model IEnumerable<AttendanceMachineConnectionLog>

@{
    ViewData["Title"] = "Connection Logs";
    ViewData["PageIcon"] = "fas fa-plug";
}

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-body">
                <table id="connectionLogsTable" class="table table-striped table-bordered table-hover" style="width:100%">
                    <thead>
                        <tr>
                            <th style="display:none">ID</th>
                            <th>Machine Name</th>
                            <th>Machine IP</th>
                            <th>Connection Start Time</th>
                            <th>Connection End Time</th>
                            <th>Status</th>
                            <th>Error Message</th>
                            <th>Records Read</th>
                            <th>Last Records Fetching</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#connectionLogsTable').DataTable({
                "processing": true,
                "serverSide": true,
                "ajax": {
                    "url": "/HR/AttendanceMachineConnectionLogs/GetConnectionLogs",
                    "type": "POST"
                },
                "order": [[0, "desc"]],
                "columns": [
                    { "data": "id" , "visible": false},
                    { "data": "machineName" },
                    { "data": "machine_IP"},
                    { "data": "connection_StartTime"},
                    { "data": "connection_EndTime", "defaultContent": "" },
                    {
                        "data": "status",
                        "render": function (data) {
                            return data === "Success"
                                ? '<span class="badge bg-success"><i class="fas fa-check-circle me-1"></i>Success</span>'
                                : '<span class="badge bg-danger"><i class="fas fa-times-circle me-1"></i>Failed</span>';
                        }
                    },
                    { "data": "errorMessage", "defaultContent": "N/A" },
                    { "data": "recordsRead", "defaultContent": "0" },
                    { "data": "lastFetching" }
                ],
                "dom": '<"row"<"col-sm-2"l><"col-sm-10"Bf>>' +
                       '<"row"<"col-sm-12"tr>>' +
                       '<"row"<"col-sm-5"i><"col-sm-7"p>>',
                "pageLength": 10,
                "lengthMenu": [[10, 25, 50, 100,200,500,1000], [10, 25, 50, 100,200,500,1000]],
                "buttons": [
                    { extend: 'copy',  text: '<i class="fas fa-copy"></i> Copy',  className: 'btn btn-dt-primary btn-sm' },
                    {
                        text: '<i class="fas fa-file-excel"></i> Export All (Excel)',
                        className: 'btn btn-dt-success btn-sm',
                        action: function (e, dt, button, config) {
                            var searchValue = $('#connectionLogsTable_filter input').val();
                            var sortColumn = dt.order()[0][0];
                            var sortDirection = dt.order()[0][1];
                            window.location.href = '/HR/AttendanceMachineConnectionLogs/ExportConnectionLogs' +
                                '?search=' + encodeURIComponent(searchValue || '') +
                                '&sortColumn=' + encodeURIComponent(sortColumn || '') +
                                '&sortDirection=' + encodeURIComponent(sortDirection || '');
                        }
                    },
                    { extend: 'pdf',   text: '<i class="fas fa-file-pdf"></i> PDF',   className: 'btn btn-dt-danger btn-sm' },
                    { extend: 'print', text: '<i class="fas fa-print"></i> Print', className: 'btn btn-dt-warning btn-sm' }
                ]
            });
        });
    </script>
}
