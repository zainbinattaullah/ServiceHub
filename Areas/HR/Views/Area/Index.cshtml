@{
    ViewData["Title"] = "Areas";
    ViewData["PageIcon"] = "fas fa-map-marker-alt";
}

<div class="row">
    <div class="col-lg-12">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="fas fa-check-circle me-1"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card">
            <div class="card-header d-flex align-items-center flex-wrap gap-2">
                <a asp-action="Create" class="btn btn-sm btn-gradient">
                    <i class="fas fa-plus me-1"></i> Add Area
                </a>
                <a asp-action="Export" class="btn btn-sm btn-gradient ms-1">
                    <i class="fas fa-file-excel me-1"></i> Export Excel
                </a>
            </div>
            <div class="card-body">
                <table id="areaTable" class="table table-striped table-bordered table-hover" style="width:100%">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Active</th>
                            <th>Created At</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#areaTable').DataTable({
                processing: true,
                serverSide: true,
                ajax: { url: '/HR/Area/GetAreas', type: 'POST' },
                columns: [
                    { data: 'code',        name: 'code' },
                    { data: 'name',        name: 'name' },
                    { data: 'description', name: 'description', defaultContent: '—' },
                    {
                        data: 'isActive', name: 'isActive',
                        render: function (d, t, row) {
                            return `<span class="badge ${d ? 'bg-success' : 'bg-danger'} toggle-active"
                                        style="cursor:pointer" data-id="${row.id}" title="Click to toggle">
                                        ${d ? 'Yes' : 'No'}
                                    </span>`;
                        }
                    },
                    { data: 'createdAt', name: 'createdAt' },
                    {
                        data: null, orderable: false, searchable: false,
                        render: function (d, t, row) {
                            return `<a href="/HR/Area/Edit/${row.id}" class="btn btn-sm btn-gradient">
                                        <i class="fas fa-edit me-1"></i>Edit
                                    </a>`;
                        }
                    }
                ],
                dom: '<"row"<"col-sm-2"l><"col-sm-10"f>>' +
                     '<"row"<"col-sm-12"tr>>' +
                     '<"row"<"col-sm-5"i><"col-sm-7"p>>',
                pageLength: 10,
                lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]]
            });

            $('#areaTable tbody').on('click', '.toggle-active', function () {
                var id  = $(this).data('id');
                var $el = $(this);
                $.post('/HR/Area/ToggleActive', { id: id }, function (res) {
                    if (res.success) {
                        $el.text(res.isActive ? 'Yes' : 'No')
                           .removeClass('bg-success bg-danger')
                           .addClass(res.isActive ? 'bg-success' : 'bg-danger');
                    }
                });
            });
        });
    </script>
}
