@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Employee Enrollments";
    ViewData["PageIcon"] = "fas fa-fingerprint";
}

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-body">
                <table id="enrollmentsTable" class="table table-striped table-bordered table-hover" style="width:100%">
                    <thead>
                        <tr>
                            <th style="display:none">ID</th>
                            <th>Employee Code</th>
                            <th>Employee Name</th>
                            <th>Machine IP</th>
                            <th>Privilege</th>
                            <th>Department</th>
                            <th>Created At</th>
                            <th>Synced</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var table = $('#enrollmentsTable').DataTable({
                processing: true,
                serverSide: true,
                ajax: {
                    url: '/HR/Enrollment/GetEnrollments',
                    type: 'POST'
                },
                columns: [
                    { data: 'id', visible: false },
                    { data: 'employeeCode' },
                    { data: 'employeeName' },
                    { data: 'machineIP' },
                    { data: 'privilege' },
                    {data: 'department',
                     render: function (d) {
                         return d ? d : '<span class="text-muted">—</span>';
                     }
                    },
                    { data: 'createdAt' },
                    {
                        data: 'isSynced',
                        render: function (d) {
                            return d
                                ? '<span class="badge bg-success"><i class="fas fa-check me-1"></i>Synced</span>'
                                : '<span class="badge bg-warning text-dark"><i class="fas fa-clock me-1"></i>Pending</span>';
                        }
                    },
                    {
                        data: 'isActive',
                        orderable: false,
                        render: function (d, t, row) {
                            return d
                                ? '<span class="badge bg-success"><i class="fas fa-user-check me-1"></i>Active</span>'
                                : '<span class="badge bg-danger"><i class="fas fa-user-slash me-1"></i>Inactive</span>';
                        }
                    },
                    {
                        data: null,
                        orderable: false,
                        render: function (d, t, row) {
                            var retryBtn = !row.isSynced
                                ? '<button class="btn btn-sm btn-gradient retry-send me-1" data-id="' + row.id + '"><i class="fas fa-redo me-1"></i>Retry</button>'
                                : '';
                            var toggleLabel = row.isActive
                                ? '<i class="fas fa-user-slash me-1"></i>Deactivate'
                                : '<i class="fas fa-user-check me-1"></i>Activate';
                            var toggleClass = row.isActive ? 'btn-danger' : 'btn-success';
                            var toggleBtn = '<button class="btn btn-sm ' + toggleClass + ' toggle-active" data-code="' + row.employeeCode + '" data-active="' + row.isActive + '">' + toggleLabel + '</button>';
                            return retryBtn + toggleBtn;
                        }
                    }
                ],
                dom: '<"row"<"col-sm-2"l><"col-sm-10"Bf>>' +
                     '<"row"<"col-sm-12"tr>>' +
                     '<"row"<"col-sm-5"i><"col-sm-7"p>>',
                pageLength: 10,
                lengthMenu: [[10, 25, 50, 100,200,500,1000], [10,25,50,100,200,500,1000]],
                buttons: [
                    { extend: 'copy',  text: '<i class="fas fa-copy"></i> Copy',  className: 'btn btn-dt-primary btn-sm' },
                    {
                        text: '<i class="fas fa-file-excel"></i> Export All (Excel)',
                        className: 'btn btn-dt-success btn-sm',
                        action: function (e, dt, button, config) {
                            var searchValue = $('#enrollmentsTable_filter input').val();
                            var sortColumn = dt.order()[0][0];
                            var sortDirection = dt.order()[0][1];
                            window.location.href = '/HR/Enrollment/ExportEnrollments' +
                                '?search=' + encodeURIComponent(searchValue || '') +
                                '&sortColumn=' + encodeURIComponent(sortColumn || '') +
                                '&sortDirection=' + encodeURIComponent(sortDirection || '');
                        }
                    },
                    { extend: 'pdf',   text: '<i class="fas fa-file-pdf"></i> PDF',   className: 'btn btn-dt-danger btn-sm' },
                    { extend: 'print', text: '<i class="fas fa-print"></i> Print', className: 'btn btn-dt-warning btn-sm' }
                ]
            });

            // Retry send
            $('#enrollmentsTable').on('click', '.retry-send', function () {
                var id = $(this).data('id');
                var btn = $(this);
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span>Retrying...');
                $.post('/HR/Enrollment/RetrySend', { id: id })
                    .done(function (res) {
                        if (res.success) {
                            table.ajax.reload(null, false);
                        } else {
                            alert('Failed: ' + (res.message || 'Unknown'));
                            btn.prop('disabled', false).html('<i class="fas fa-redo me-1"></i>Retry');
                        }
                    })
                    .fail(function (xhr) {
                        alert('Error: ' + xhr.responseText);
                        btn.prop('disabled', false).html('<i class="fas fa-redo me-1"></i>Retry');
                    });
            });

            // Toggle Active / Deactivate
            $('#enrollmentsTable').on('click', '.toggle-active', function () {
                var btn  = $(this);
                var code = btn.data('code');
                var isActive = btn.data('active');
                var label = isActive ? 'deactivate' : 'activate';
                if (!confirm('Are you sure you want to ' + label + ' employee ' + code + '?\nThis will update all ZKTeco machines they are registered on.')) return;

                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span>Processing...');

                $.ajax({
                    url: '/HR/Enrollment/ToggleActive',
                    type: 'POST',
                    contentType: 'application/json',
                    headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                    data: JSON.stringify({ employeeCode: code }),
                    success: function (res) {
                        if (res.success) {
                            table.ajax.reload(null, false);
                        } else {
                            alert('Failed: ' + (res.message || 'Unknown error'));
                            btn.prop('disabled', false);
                        }
                    },
                    error: function (xhr) {
                        alert('Server error: ' + xhr.status);
                        btn.prop('disabled', false);
                    }
                });
            });
        });
    </script>
    @Html.AntiForgeryToken()
}
