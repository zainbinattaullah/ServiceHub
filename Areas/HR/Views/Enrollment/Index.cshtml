@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Employee Enrollments";
}

<style>
    .Cust-card-margin { margin: 5px !important; }
    .table { margin-bottom: 0 !important; }

    /* Custom styles for DataTables buttons */
    .dt-buttons .btn {
        /* Add spacing between buttons */
        margin-right: 5px !important;
    }

        .dt-buttons .btn i {
            /* Add spacing between icon and text */
            margin-right: 5px !important;
        }

    /* Specific button colors */
    .btn-dt-primry {
        background-color: #0d6efd !important;
        border-color: #0d6efd !important;
        border-radius: 5px !important;
        color: white !important;
    }

    .btn-dt-success {
        background-color: #198754 !important;
        border-color: #198754 !important;
        border-radius: 5px !important;
        color: white !important;
    }

    .btn-dt-info {
        background-color: #0dcaf0 !important;
        border-color: #0dcaf0 !important;
        border-radius: 5px !important;
        color: white !important;
    }

    .btn-dt-danger {
        background-color: #dc3545 !important;
        border-color: #dc3545 !important;
        border-radius: 5px !important;
        color: white !important;
    }

    .btn-dt-warning {
        background-color: #ffc107 !important;
        border-color: #ffc107 !important;
        border-radius: 5px !important;
        color: white !important;
    }
</style>

<div class="row">
    <div class="col-lg-12">
        <div class="card Cust-card-margin">
            <div class="card-header">
                <div class="card-title">
                    <h2>Employee Enrollments</h2>
                </div>
            </div>
            <div class="card-body">
                <table id="enrollmentsTable" class="table table-striped table-bordered table-responsive" style="width:100% !important">
                    <thead>
                        <tr>
                            <th style="display:none">ID</th>
                            <th>Employee Code</th>
                            <th>Employee Name</th>
                            <th>Machine IP</th>
                            <th>Privilege</th>
                            <th>Created At</th>
                            <th>Synced</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var table = $('#enrollmentsTable').DataTable({
                processing: true,
                serverSide: true,
                ajax: {
                    url: '/HR/Enrollment/GetEnrollments',
                    type: 'POST'
                },
                columns: [
                    { data: 'id', visible: false },
                    { data: 'employeeCode' },
                    { data: 'employeeName' },
                    { data: 'machineIP' },
                    { data: 'privilege' },
                    { data: 'createdAt' },
                    {
                        data: 'isSynced',
                        render: function (d) { return d ? '<span class="badge bg-success">Synced</span>' : '<span class="badge bg-warning">Pending</span>'; }
                    },
                    {
                        data: null,
                        orderable: false,
                        render: function (row) {
                            if (!row.isSynced) {
                                return '<button class="btn btn-sm btn-primary retry-send" data-id="' + row.id + '">Retry</button>';
                            }
                            return '';
                        }
                    }
                ],
                dom: '<"row"<"col-sm-2"l><"col-sm-10"Bf>>' +
                     '<"row"<"col-sm-12"tr>>' +
                     '<"row"<"col-sm-5"i><"col-sm-7"p>>',
                pageLength: 10,
                lengthMenu: [[10, 25, 50, 100,200,500,1000], [10,25,50,100,200,500,1000]],
                buttons: [
                    { extend: 'copy', text: '<i class="fas fa-copy"></i> Copy', className: 'btn btn-dt-primry btn-sm' },
                    {
                        text: '<i class="fas fa-file-excel"></i> Export All (Excel)',
                        className: 'btn btn-dt-success btn-sm',
                        action: function (e, dt, button, config) {
                            var searchValue = $('#enrollmentsTable_filter input').val();
                            var sortColumn = dt.order()[0][0];
                            var sortDirection = dt.order()[0][1];
                            window.location.href = '/HR/Enrollment/ExportEnrollments' +
                                '?search=' + encodeURIComponent(searchValue || '') +
                                '&sortColumn=' + encodeURIComponent(sortColumn || '') +
                                '&sortDirection=' + encodeURIComponent(sortDirection || '');
                        }
                    },
                    { extend: 'pdf', text: '<i class="fas fa-file-pdf"></i> PDF', className: 'btn btn-dt-danger btn-sm' },
                    { extend: 'print', text: '<i class="fas fa-print"></i> Print', className: 'btn btn-dt-warning btn-sm' }
                ]
            });

            // Retry send
            $('#enrollmentsTable').on('click', '.retry-send', function () {
                var id = $(this).data('id');
                var btn = $(this);
                btn.prop('disabled', true);
                $.post('/HR/Enrollment/RetrySend', { id: id })
                    .done(function (res) {
                        if (res.success) {
                            table.ajax.reload(null, false);
                        } else {
                            alert('Failed: ' + (res.message || 'Unknown'));
                            btn.prop('disabled', false);
                        }
                    })
                    .fail(function (xhr) {
                        alert('Error: ' + xhr.responseText);
                        btn.prop('disabled', false);
                    });
            });
        });
    </script>
}
