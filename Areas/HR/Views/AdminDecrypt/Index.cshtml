@{
    ViewData["Title"] = "Admin Password Decryption";
    ViewData["PageIcon"] = "fas fa-lock";
}

<div class="row">
    <div class="col-lg-8">
        @if (!string.IsNullOrEmpty(ViewBag.Error))
        {
            <div class="alert alert-danger"><i class="fas fa-exclamation-circle me-1"></i>@ViewBag.Error</div>
        }

        <div class="card">
            <div class="card-body">
                <form asp-action="Decrypt" method="post">
                    <div class="mb-3">
                        <label for="encryptedText" class="form-label">Encrypted Password</label>
                        <textarea name="encryptedText" id="encryptedText" class="form-control" rows="4" placeholder="Paste encrypted text here...">@ViewBag.Original</textarea>
                    </div>
                    <button type="submit" class="btn btn-gradient">
                        <i class="fas fa-unlock me-1"></i> Decrypt
                    </button>
                </form>

                @if (ViewBag.Decrypted != null)
                {
                    <div class="mt-4 p-3 rounded" style="background:var(--sh-card-bg); border:1px solid var(--sh-border);">
                        <label class="form-label fw-bold">Decrypted Password</label>
                        <textarea class="form-control" rows="2" readonly style="background:#f8f9fa;">@ViewBag.Decrypted</textarea>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
