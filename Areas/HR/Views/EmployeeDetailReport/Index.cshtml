@{
    ViewData["Title"] = "Employee Detail Report";
    ViewData["PageIcon"] = "fas fa-chart-bar";
}

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header d-flex align-items-center flex-wrap gap-2">
                <div class="d-flex gap-2 flex-wrap">
                    <a href="/HR/EmployeeDetailReport/ExportListExcel" class="btn btn-sm btn-gradient-success">
                        <i class="fas fa-file-excel me-1"></i> Export All (Excel)
                    </a>
                    <button id="btnExportFiltered" class="btn btn-sm btn-gradient" title="Export current filtered view">
                        <i class="fas fa-download me-1"></i> Export Filtered (Excel)
                    </button>
                </div>
            </div>
            <div class="card-body">

                <!-- Summary tiles -->
                <div class="row g-3 mb-4" id="summaryStats" style="display:none">
                    <div class="col-6 col-md-3">
                        <div class="sh-stat-card card border-0">
                            <div class="card-body d-flex align-items-center gap-3 p-3">
                                <div class="sh-stat-icon" style="background:var(--sh-grad-primary)">
                                    <i class="fas fa-users"></i>
                                </div>
                                <div>
                                    <div class="sh-stat-value" id="statTotal">—</div>
                                    <div class="sh-stat-label">Total Employees</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="sh-stat-card card border-0">
                            <div class="card-body d-flex align-items-center gap-3 p-3">
                                <div class="sh-stat-icon" style="background:var(--sh-grad-success)">
                                    <i class="fas fa-fingerprint"></i>
                                </div>
                                <div>
                                    <div class="sh-stat-value" id="statEnrolled">—</div>
                                    <div class="sh-stat-label">Biometric Enrolled</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="sh-stat-card card border-0">
                            <div class="card-body d-flex align-items-center gap-3 p-3">
                                <div class="sh-stat-icon" style="background:var(--sh-grad-warning)">
                                    <i class="fas fa-exclamation-triangle"></i>
                                </div>
                                <div>
                                    <div class="sh-stat-value" id="statNotEnrolled">—</div>
                                    <div class="sh-stat-label">Not Enrolled</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="sh-stat-card card border-0">
                            <div class="card-body d-flex align-items-center gap-3 p-3">
                                <div class="sh-stat-icon" style="background:var(--sh-grad-danger)">
                                    <i class="fas fa-shield-alt"></i>
                                </div>
                                <div>
                                    <div class="sh-stat-value" id="statFraud">—</div>
                                    <div class="sh-stat-label">Fraud Alerts</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <table id="empTable"
                       class="table table-striped table-bordered table-hover"
                       style="width:100%">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Employee ID</th>
                            <th>Name</th>
                            <th>Biometric Status</th>
                            <th>Fingers</th>
                            <th>Machines</th>
                            <th>Last Attendance</th>
                            <th>Enrollment Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
$(document).ready(function () {
    var totalCount = 0, enrolledCount = 0, notEnrolledCount = 0, fraudCount = 0;

    var table = $('#empTable').DataTable({
        processing: true,
        serverSide: true,
        ajax: {
            url: '/HR/EmployeeDetailReport/GetEmployees',
            type: 'POST',
            dataSrc: function(json) {
                totalCount       = json.recordsFiltered;
                enrolledCount    = json.data.filter(function(r){ return r.biometricStatus === 'Active'; }).length;
                notEnrolledCount = json.data.filter(function(r){ return r.biometricStatus === 'Not Enrolled'; }).length;
                fraudCount       = json.data.filter(function(r){ return r.fraudAlert; }).length;
                $('#statTotal').text(totalCount);
                $('#statEnrolled').text(enrolledCount);
                $('#statNotEnrolled').text(notEnrolledCount);
                $('#statFraud').text(fraudCount);
                $('#summaryStats').css('display','');
                return json.data;
            },
            error: function(xhr) {
                try {
                    var resp = JSON.parse(xhr.responseText);
                    if (resp.error) alert(resp.error);
                } catch(e) { console.error('DataTable AJAX error', xhr.status); }
            }
        },
        columns: [
            { data: null, render: function(d,t,r,m){ return m.row+1+m.settings._iDisplayStart; }, orderable:false, width:'40px' },
            { data: 'empNo' },
            { data: 'empName' },
            {
                data: 'biometricStatus',
                render: function(d) {
                    return d === 'Active'
                        ? '<span class="badge bg-success"><i class="fas fa-fingerprint me-1"></i>Active</span>'
                        : '<span class="badge bg-secondary"><i class="fas fa-times me-1"></i>Not Enrolled</span>';
                }
            },
            {
                data: 'totalFingersEnrolled',
                render: function(d) {
                    if (!d) return '<span class="text-muted">—</span>';
                    var cls = d > 10 ? 'bg-danger' : 'bg-primary';
                    return '<span class="badge '+cls+'">'+d+'</span>';
                }
            },
            {
                data: 'machinesAssigned',
                render: function(d) {
                    return d > 0 ? '<span class="badge bg-info text-dark">'+d+'</span>' : '<span class="text-muted">—</span>';
                }
            },
            { data: 'lastAttendance', render: function(d){ return d || '<span class="text-muted">Never</span>'; } },
            { data: 'enrollmentDate', render: function(d){ return d || '—'; } },
            {
                data: 'isActive',
                render: function(d, t, row) {
                    if (t === 'export') return d ? 'Active' : 'Inactive';
                    var badge = d ? '<span class="badge bg-success me-1">Active</span>'
                                  : '<span class="badge bg-danger me-1">Inactive</span>';
                    var btnCls = d ? 'btn-danger' : 'btn-success';
                    var btnLbl = d ? '<i class="fas fa-user-slash me-1"></i>Deactivate'
                                  : '<i class="fas fa-user-check me-1"></i>Activate';
                    var toggleBtn = '<button class="btn btn-sm ' + btnCls + ' toggle-active-emp" '
                        + 'data-code="' + (row.empNo || '') + '" data-active="' + d + '">' + btnLbl + '</button>';
                    return badge + toggleBtn;
                }
            },
            {
                data: 'empNo', orderable: false,
                render: function(d, t, r) {
                    var alert = r.fraudAlert
                        ? ' <span class="badge bg-danger" title="'+(r.fraudReason||'')+'"><i class="fas fa-exclamation-triangle"></i></span>'
                        : '';
                    return '<a href="/HR/EmployeeDetailReport/Detail/'+encodeURIComponent(d)+'" '
                         + 'class="btn btn-sm btn-gradient"><i class="fas fa-eye me-1"></i>View</a>' + alert;
                }
            }
        ],
        createdRow: function(row, data) {
            if (data.fraudAlert) $(row).addClass('fraud-row').attr('title', data.fraudReason);
        },
        dom: '<"row"<"col-sm-2"l><"col-sm-10"Bf>>' +
             '<"row"<"col-sm-12"tr>>' +
             '<"row"<"col-sm-5"i><"col-sm-7"p>>',
        pageLength: 25,
        lengthMenu: [[10,25,50,100],[10,25,50,100]],
        order: [[1,'asc']],
        buttons: [
            { extend:'copy',  text:'<i class="fas fa-copy"></i> Copy',  className:'btn btn-dt-primary btn-sm' },
            { extend:'print', text:'<i class="fas fa-print"></i> Print', className:'btn btn-dt-warning btn-sm' },
            { extend:'pdf',   text:'<i class="fas fa-file-pdf"></i> PDF', className:'btn btn-dt-danger btn-sm',
              exportOptions: { columns: [0,1,2,3,4,5,6,7,8] } },
            { extend:'excel', text:'<i class="fas fa-file-excel"></i> Excel', className:'btn btn-dt-success btn-sm',
              exportOptions: { columns: [0,1,2,3,4,5,6,7,8] } }
        ]
    });

    // Export filtered Excel via server
    $('#btnExportFiltered').on('click', function() {
        var sv = table.search();
        window.location.href = '/HR/EmployeeDetailReport/ExportListExcel?search=' + encodeURIComponent(sv || '');
    });

    // Toggle Active / Deactivate from Employee Detail Report
    $('table').on('click', '.toggle-active-emp', function () {
        var btn      = $(this);
        var code     = btn.data('code');
        var isActive = btn.data('active');
        var label    = isActive ? 'deactivate' : 'activate';
        if (!confirm('Are you sure you want to ' + label + ' employee ' + code + '?\nThis will update all ZKTeco machines they are registered on.')) return;

        btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span>Processing...');

        $.ajax({
            url: '/HR/EmployeeDetailReport/ToggleActive',
            type: 'POST',
            contentType: 'application/json',
            headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
            data: JSON.stringify({ employeeCode: code }),
            success: function (res) {
                if (res.success) {
                    table.ajax.reload(null, false);
                } else {
                    alert('Failed: ' + (res.message || 'Unknown error'));
                    btn.prop('disabled', false);
                }
            },
            error: function (xhr) {
                alert('Server error: ' + xhr.status);
                btn.prop('disabled', false);
            }
        });
    });
});
</script>
@Html.AntiForgeryToken()
}
